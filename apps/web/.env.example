# 复制为 .env.local 后填入真实值（.env.local 不提交 git）

# Neon Postgres（dev 暂用美国区；真实客户数据前迁加拿大，PIPEDA）——注意 ?sslmode=require
DATABASE_URL="postgresql://user:password@ep-xxx.<region>.aws.neon.tech/easetax?sslmode=require"

# JWT 签名密钥（随机长字符串）
JWT_SECRET="请替换为随机长字符串"

# ---- 外部集成（到对应阶段填；缺失则用 mock provider）----
# P2 OCR — Veryfi（Settings→Keys: app.veryfi.com/api/settings/keys/；见 docs/20260708-veryfi-setup.md）
VERYFI_CLIENT_ID=""
VERYFI_API_KEY=""
VERYFI_USERNAME=""
VERYFI_CLIENT_SECRET=""   # HMAC 签名用（若账号强制签名）

# P3 分类 — Claude（缺失走 mock）
ANTHROPIC_API_KEY=""

# P5 录入 — Intuit QBO sandbox（缺失走 mock）
QBO_CLIENT_ID=""
QBO_CLIENT_SECRET=""
QBO_REDIRECT_URI="http://localhost:3000/api/clients/callback"
QBO_ENVIRONMENT="sandbox"

# 邮件入站 webhook 签名密钥（P1）
INBOUND_WEBHOOK_SECRET=""
